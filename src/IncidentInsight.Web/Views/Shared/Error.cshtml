@model ErrorViewModel
@inject IWebHostEnvironment HostEnvironment
@{
    ViewData["Title"] = "エラー";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="text-center mb-4">
        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
        <h1 class="text-danger mt-3">エラーが発生しました</h1>
        <p class="lead text-muted">リクエストの処理中に問題が発生しました。時間を置いて再度お試しください。</p>
    </div>

    @if (Model.ShowRequestId)
    {
        <div class="card mx-auto" style="max-width: 560px;">
            <div class="card-body">
                <p class="mb-1"><strong>リクエスト ID:</strong></p>
                <code class="d-block text-break">@Model.RequestId</code>
                <p class="small text-muted mt-2 mb-0">お問い合わせ時はこの ID をご連絡ください。</p>
            </div>
        </div>
    }

    <div class="text-center mt-4">
        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">
            <i class="bi bi-house"></i> ダッシュボードへ戻る
        </a>
    </div>

    @if (HostEnvironment.IsDevelopment())
    {
        <div class="alert alert-warning mt-5" role="alert">
            <h5 class="alert-heading">開発環境向け情報</h5>
            <p class="mb-0 small">
                詳細なスタックトレースは Developer Exception Page で確認できます。
                <strong>本番環境ではこの画面は表示されません。</strong>
            </p>
        </div>
    }
</div>
