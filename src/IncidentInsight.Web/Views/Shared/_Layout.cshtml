@* 全ページで共通利用するレイアウトテンプレート(ヘッダ・ナビ・フッタ) *@
@* 時刻は IClock 経由で取得する(プロジェクト規約) *@
@inject IClock Clock
@{
    @* 現在のコントローラ名を取得し、ナビのアクティブ表示判定に使う *@
    var currentController = ViewContext.RouteData.Values["controller"] as string ?? "";
    @* 「現在の場所」と nav 項目の対応を判定するローカル関数 *@
    Func<string, string> navActive = (controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* テーマカラー(ブラウザ UI 連動) *@
    <meta name="theme-color" content="#155a9e" />
    @* 各ページで設定される Title を連結してブラウザタブに表示 *@
    <title>@ViewData["Title"] — 医療インシデント管理システム</title>
    @* Bootstrap 5 の CSS(CDN配信) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1VsMDVxYGkbvXsGpcB4fBI9e1lkChfS"
          crossorigin="anonymous" />
    @* Bootstrap Icons の CSS(CDN) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @* Web フォント: Inter(Latin/数字、Modern SaaS 標準) + Noto Sans JP(和文) *@
    @* preconnect で Google Fonts へのコネクション確立を先回りし、フォント FOIT を回避(display=swap) *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Noto+Sans+JP:wght@400;500;700&amp;display=swap" />
    @* アプリ固有のスタイル(キャッシュバスト用に asp-append-version="true") *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @* テーマのちらつき防止: CSS 適用前に保存済みテーマを <html> に反映しておく(FOUC 回避) *@
    <script>
        // 前回ユーザーが選んだテーマ(light/dark)を localStorage から取り出す
        (function () {
            try {
                // 保存されているテーマ名を読む(無ければ null)
                var saved = localStorage.getItem('ii-theme');
                // dark が保存されていたときだけ、描画前に data-theme="dark" を付ける
                if (saved === 'dark') { document.documentElement.setAttribute('data-theme', 'dark'); }
            } catch (e) { /* プライベートモード等で失敗しても無視する */ }
        })();
    </script>
</head>
<body>
    @* 上部ナビゲーションバー(粘着) *@
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid px-4">
            @* ブランドロゴ(クリックでダッシュボードへ) *@
            <a class="navbar-brand fw-bold d-flex align-items-center" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shield-plus me-2 fs-5"></i>
                <span>IncidentInsight</span>
                @* サブブランド：英名と日本語名を併記して医療現場でも識別しやすくする *@
                <span class="d-none d-md-inline ms-2 text-white-50 small fw-normal">医療インシデント管理</span>
            </a>
            @* モバイル幅(<lg)ではハンバーガーを開かないと collapse 内の「新規登録」が見えないため、collapse の外側にもクイックアクションボタンを常駐させる(d-lg-none で lg 以上では非表示) *@
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-light btn-sm d-lg-none ms-auto me-2" asp-controller="Incidents" asp-action="Create" aria-label="新規登録">
                    <i class="bi bi-plus-circle text-primary"></i>
                </a>
            }
            @* モバイル用ハンバーガーメニュー *@
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false" aria-label="メニューを開く">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                @* 左側メニュー(機能へのリンク) *@
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        @* ダッシュボードへのリンク(Home コントローラなら active) *@
                        <a class="nav-link @navActive("Home")" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>ダッシュボード
                        </a>
                    </li>
                    <li class="nav-item">
                        @* インシデント一覧(Incidents/CauseAnalyses/IncidentMeasures は同一機能群として active 化) *@
                        <a class="nav-link @(currentController is "Incidents" or "CauseAnalyses" or "IncidentMeasures" ? "active" : "")"
                           asp-controller="Incidents" asp-action="Index">
                            <i class="bi bi-clipboard2-pulse me-1"></i>インシデント
                        </a>
                    </li>
                    <li class="nav-item">
                        @* 再発防止策カンバンへのリンク *@
                        <a class="nav-link @navActive("PreventiveMeasures")" asp-controller="PreventiveMeasures" asp-action="Index">
                            <i class="bi bi-check2-square me-1"></i>再発防止策
                        </a>
                    </li>
                    <li class="nav-item">
                        @* 分析画面へのリンク *@
                        <a class="nav-link @navActive("Analytics")" asp-controller="Analytics" asp-action="Index">
                            <i class="bi bi-bar-chart-line me-1"></i>分析・集計
                        </a>
                    </li>
                    @* 監査ログへのリンクは管理者のみ表示(ロール名は AppRoles 定数で参照) *@
                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <li class="nav-item">
                            @* 監査ログ画面へのリンク *@
                            <a class="nav-link @navActive("AuditLogs")" asp-controller="AuditLogs" asp-action="Index">
                                <i class="bi bi-shield-check me-1"></i>監査ログ
                            </a>
                        </li>
                    }
                </ul>
                @* ログイン済みユーザーのみ右側メニューを表示 *@
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        @* ダークモード切替ボタン(クリックで light↔dark を反転、site.js が処理) *@
                        <li class="nav-item me-lg-2">
                            <button type="button" class="theme-toggle" aria-label="テーマ切替" title="ダークモード切替">
                                @* 月アイコン(ライト時に表示)とサンアイコン(ダーク時に表示)を両方置き、CSS で出し分ける *@
                                <i class="bi bi-moon-stars-fill"></i>
                                <i class="bi bi-sun-fill"></i>
                            </button>
                        </li>
                        @* 新規登録のクイックアクション(常時アクセス可能) *@
                        <li class="nav-item me-lg-2">
                            <a class="btn btn-light btn-sm fw-semibold" asp-controller="Incidents" asp-action="Create">
                                <i class="bi bi-plus-circle me-1 text-primary"></i>新規登録
                            </a>
                        </li>
                        <li class="nav-item me-lg-2">
                            @* ログインユーザー名とロールバッジ *@
                            <span class="navbar-text small text-white">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                                @* 管理者バッジ *@
                                @if (User.IsInRole("Admin"))
                                {
                                    <span class="badge bg-warning text-dark ms-1">Admin</span>
                                }
                                @* リスクマネージャーバッジ *@
                                else if (User.IsInRole("RiskManager"))
                                {
                                    <span class="badge bg-info text-dark ms-1">Risk Mgr</span>
                                }
                            </span>
                        </li>
                        <li class="nav-item">
                            @* ログアウトボタン(POST 送信) *@
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @* CSRF 対策トークン *@
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-light btn-sm">
                                    <i class="bi bi-box-arrow-right me-1"></i>ログアウト
                                </button>
                            </form>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    @* メイン領域 *@
    <div class="container-fluid mt-3 px-4">
        @* 成功トースト(TempData["Success"] が設定されていれば表示) *@
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="閉じる"></button>
            </div>
        }
        @* 警告トースト(TempData["Warning"] が設定されていれば表示) *@
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="閉じる"></button>
            </div>
        }
        <main role="main" class="pb-4">
            @* 各ビューの内容をここに埋め込む *@
            @RenderBody()
        </main>
    </div>

    @* フッター *@
    <footer class="app-footer py-3 mt-4">
        <div class="container-fluid px-4 text-muted small d-flex flex-wrap justify-content-between gap-2">
            <span><i class="bi bi-shield-plus me-1 text-primary"></i>医療インシデント管理システム — 安全な医療の実現のために</span>
            <span class="text-muted">© @Clock.Now.Year IncidentInsight</span>
        </div>
    </footer>

    @* jQuery(ローカル配信) *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @* Bootstrap の JS(CDN配信) *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    @* Chart.js(グラフ描画用、CDN 配信) *@
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    @* アプリ固有 JavaScript *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @* 各ページ固有のスクリプト section があれば挿入 *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
