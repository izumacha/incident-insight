@{
    @* ブラウザタブに表示するタイトル *@
    ViewData["Title"] = "アクセス拒否";
}

@* 権限不足時に表示されるメッセージブロック(中央寄せ) *@
<div class="text-center py-5">
    @* エラーアイコン(赤色の盾) *@
    <i class="bi bi-shield-x display-1 text-danger"></i>
    @* 見出し *@
    <h3 class="mt-3">アクセス権限がありません</h3>
    @* 説明文 *@
    <p class="text-muted">このページにアクセスするための権限がありません。<br />管理者に権限付与を依頼してください。</p>
    @* ダッシュボードに戻るリンクボタン *@
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-2">
        <i class="bi bi-house me-1"></i>ダッシュボードへ戻る
    </a>
</div>
