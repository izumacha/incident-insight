@* このビューで扱う ViewModel の型を宣言 *@
@model IncidentInsight.Web.Models.ViewModels.LoginViewModel
@* 開発/本番の判定に使う IWebHostEnvironment を DI で受け取る *@
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@{
    @* ブラウザタブのタイトル *@
    ViewData["Title"] = "ログイン";
    @* このページではレイアウトを使わず独立 HTML を出力する *@
    Layout = null;
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* ブラウザの UI もブランドカラーに合わせる *@
    <meta name="theme-color" content="#155a9e" />
    <title>IncidentInsight — ログイン</title>
    @* Bootstrap 5 の CSS を CDN から読み込む(_Layout と同じ 5.3.3 + SRI に統一) *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    @* Bootstrap Icons の CSS を CDN から読み込む *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @* Web フォント: Inter + Noto Sans JP (_Layout と揃える)。preconnect で初回読み込みを高速化 *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Noto+Sans+JP:wght@400;500;700&amp;display=swap" />
    @* アプリ固有スタイル(login-hero など) *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@* ログインカードを画面中央のヒーロー背景上に配置 *@
<div class="login-hero">
    <div class="card login-card">
        <div class="card-body p-4 p-md-5">
            @* ブランドアイコンとアプリ名 *@
            <div class="text-center mb-4">
                <div class="login-brand-icon">
                    <i class="bi bi-shield-plus"></i>
                </div>
                <h4 class="mt-2 mb-1 fw-bold">IncidentInsight</h4>
                <p class="text-muted small mb-0">医療インシデント管理システム</p>
            </div>

            @* バリデーションエラーがある場合のみサマリを表示 *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger small">
                    <div asp-validation-summary="All" class="mb-0"></div>
                </div>
            }

            @* ログインフォーム(POST /Account/Login) *@
            <form asp-action="Login" method="post">
                @* CSRF 対策トークン *@
                @Html.AntiForgeryToken()
                @* 認証成功後の戻り先 URL を隠しフィールドで保持 *@
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                @* メールアドレス入力欄(アイコン付き) *@
                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-medium small"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" type="email" class="form-control"
                               placeholder="admin@hospital.local" autocomplete="email" autofocus />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                @* パスワード入力欄(アイコン付き) *@
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-medium small"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                @* 「ログイン状態を保持」チェックボックス *@
                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label small"></label>
                </div>
                @* ログイン送信ボタン *@
                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-1"></i>ログイン
                </button>
            </form>

            @* 開発環境でのみデモアカウント一覧を表示(本番では非表示) *@
            @if (HostEnvironment.IsDevelopment())
            {
                <hr class="my-4" />
                <div>
                    <p class="text-muted small mb-2 text-center">
                        <i class="bi bi-info-circle me-1"></i>デモアカウント (開発環境のみ表示)
                    </p>
                    @* パスワードは表示しない: 実際の値は user-secrets の SeedAccounts 設定で
                       各開発者が決める(IdentitySeeder)ため、ここに固定値を書くと (a) 実際には
                       ログインできない誤った値になり、5 回失敗でロックアウトを誘発する、
                       (b) 認証情報をリポジトリにコミットしない方針(§9)にも反する *@
                    <table class="table table-sm table-borderless small text-muted mb-0">
                        <tbody>
                            <tr><td class="ps-0">管理者</td><td><code>admin@hospital.local</code></td></tr>
                            <tr><td class="ps-0">リスク管理</td><td><code>riskmanager@hospital.local</code></td></tr>
                        </tbody>
                    </table>
                    <p class="text-muted small mb-0 text-center">
                        パスワードは user-secrets の <code>SeedAccounts</code> 設定値(CLAUDE.md §2 参照)
                    </p>
                </div>
            }
        </div>
    </div>
</div>
@* Bootstrap の JS をフッタで読み込む(_Layout と同じ 5.3.3 + SRI に統一) *@
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
@* jQuery(ローカル配信)。このページは Layout = null で _Layout を経由しないため、
   _ValidationScriptsPartial(jquery.validate)より前にここで明示的に読み込む。
   読み込まないと「jQuery is not defined」でクライアント検証が動かない *@
<script src="~/lib/jquery/dist/jquery.min.js"></script>
@* クライアントサイドバリデーション用スクリプト *@
<partial name="_ValidationScriptsPartial" />
</body>
</html>
