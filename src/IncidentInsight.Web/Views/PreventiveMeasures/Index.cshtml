@* カンバン画面に渡される生のモデル型（IEnumerable）を宣言。ViewBag で3バケットに分けて渡される *@
@model IEnumerable<IncidentInsight.Web.Models.PreventiveMeasure>
@* IClock を DI で受け取り、今日の日付を DateTime.Today 直呼びなしで取得する *@
@inject IncidentInsight.Web.Services.IClock Clock
@{
    @* ブラウザタブのタイトル *@
    ViewData["Title"] = "再発防止策管理";
    @* 計画中バケット（未設定なら空リストにフォールバック） *@
    var planned = ViewBag.Planned as List<IncidentInsight.Web.Models.PreventiveMeasure> ?? new();
    @* 進行中バケット *@
    var inProgress = ViewBag.InProgress as List<IncidentInsight.Web.Models.PreventiveMeasure> ?? new();
    @* 完了バケット *@
    var completed = ViewBag.Completed as List<IncidentInsight.Web.Models.PreventiveMeasure> ?? new();
    @* 今日の日付を一度だけ取得してビュー内で使い回す *@
    var today = Clock.Today;
}

@* ページヘッダ *@
<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <div>
        <h2 class="mb-1"><i class="bi bi-check2-square me-2 text-success"></i>再発防止策管理</h2>
        <div class="text-muted small">計画 → 進行中 → 完了 のステータスをカンバン形式で一覧</div>
    </div>
</div>

@* 上限件数に達した場合の注意書き(絞り込み条件で対象を絞ってもらう案内。
   完了率・期限超過・再発確認の3 KPI は上限適用後のデータからの近似値になる旨も明示する) *@
@if (ViewBag.Truncated == true)
{
    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>
        表示件数の上限（@(IncidentInsight.Web.Controllers.PreventiveMeasuresController.MaxKanbanRows)件）に達したため、一部の対策のみ表示しています。
        「完了率」「期限超過」「再発確認」は表示中の対策のみの集計値です。絞り込み条件を指定して対象を絞ってください。
    </div>
}

@* 統計バー：全件・完了率・期限超過・再発確認の4枚(KPI カードと統一感のあるデザイン) *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        @* 全対策数 *@
        <div class="card kpi-card kpi-secondary shadow-sm">
            <div class="card-body py-3">
                <div class="kpi-label">全対策数</div>
                <div class="kpi-value">@ViewBag.TotalCount<span class="unit">件</span></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        @* 完了率（%表示） *@
        <div class="card kpi-card kpi-success shadow-sm">
            <div class="card-body py-3">
                <div class="kpi-label">完了率</div>
                <div class="kpi-value text-success">@ViewBag.CompletionRate<span class="unit">%</span></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        @* 期限超過件数（1件以上なら赤枠で強調） *@
        <div class="card kpi-card kpi-danger shadow-sm @(ViewBag.OverdueCount > 0 ? "border border-danger" : "")">
            <div class="card-body py-3">
                <div class="kpi-label">期限超過</div>
                <div class="kpi-value @(ViewBag.OverdueCount > 0 ? "text-danger" : "")">@ViewBag.OverdueCount<span class="unit">件</span></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        @* 再発確認件数（1件以上なら赤枠で強調） *@
        <div class="card kpi-card kpi-danger shadow-sm @(ViewBag.FailedCount > 0 ? "border border-danger" : "")">
            <div class="card-body py-3">
                <div class="kpi-label">再発確認</div>
                <div class="kpi-value @(ViewBag.FailedCount > 0 ? "text-danger" : "")">@ViewBag.FailedCount<span class="unit">件</span></div>
            </div>
        </div>
    </div>
</div>

@* 絞り込みフォーム（ステータス・担当部署・担当者名の3条件） *@
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                @{
                    @* 現在のステータス絞り込み値を取り出す *@
                    var filterStatus = ViewBag.FilterStatus as IncidentInsight.Web.Models.Enums.MeasureStatus?;
                }
                @* ステータス選択 *@
                <select name="status" class="form-select form-select-sm">
                    <option value="">ステータス（全て）</option>
                    @foreach (var s in IncidentInsight.Web.Models.Enums.EnumLabels.AllStatuses)
                    {
                        <option value="@s" selected="@(filterStatus == s)">@IncidentInsight.Web.Models.Enums.EnumLabels.Japanese(s)</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                @* 担当部署選択。選択肢は Incident.Departments(発生部署の許可リスト)ではなく、
                   実際に保存されている対策の担当部署(自由記述)からコントローラが生成した
                   一覧を使う。許可リスト由来だとリスト外の担当部署(例: 看護部)が
                   絶対にヒットしないフィルタになってしまうため *@
                <select name="responsibleDepartment" class="form-select form-select-sm">
                    <option value="">担当部署（全て）</option>
                    @* コントローラが生成した実データ由来の担当部署一覧を選択肢として並べる *@
                    @foreach (var d in (List<string>)ViewBag.ResponsibleDepartmentOptions)
                    {
                        <option value="@d" selected="@(ViewBag.FilterResponsibleDepartment == d)">@d</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                @* 担当者名の部分一致検索 *@
                <input type="text" name="responsible" class="form-control form-control-sm"
                       placeholder="担当者名で検索" value="@ViewBag.FilterResponsible" />
            </div>
            <div class="col-md-2">
                @* 絞り込み実行ボタン *@
                <button type="submit" class="btn btn-primary btn-sm">絞り込み</button>
                @* 絞り込みをクリア（無条件の一覧へ戻る） *@
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">クリア</a>
            </div>
        </form>
    </div>
</div>

@* カンバンボード本体（3バケットが全部空なら案内を表示） *@
@if (!planned.Any() && !inProgress.Any() && !completed.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-shield-check display-4 text-success d-block mb-3"></i>
            <h5>再発防止策がまだ登録されていません</h5>
            <p class="text-muted mb-3">インシデント詳細ページから再発防止策を追加できます。</p>
            @* インシデント一覧へのリンク（そこから対策を追加する導線） *@
            <a asp-controller="Incidents" asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-clipboard2-pulse me-1"></i>インシデント一覧へ
            </a>
        </div>
    </div>
}
else
{
<div class="row g-3">
    @* 計画中レーン *@
    <div class="col-xl-4">
        <div class="kanban-lane shadow-sm">
            <div class="kanban-lane-header lane-planned">
                <i class="bi bi-hourglass text-warning"></i>
                <span>計画中</span>
                @* レーン内の総数 *@
                <span class="badge bg-warning text-dark ms-1">@planned.Count</span>
                @* レーン内の超過件数（0件超なら赤バッジ）(IClock 経由の today を渡す) *@
                @if (planned.Count(m => m.IsOverdueOn(today)) > 0)
                {
                    <span class="badge bg-danger ms-1">@planned.Count(m => m.IsOverdueOn(today)) 件超過</span>
                }
            </div>
            <div class="kanban-lane-body">
                @* 各対策を _MeasureCard パーシャルで描画 *@
                @foreach (var m in planned)
                {
                    <partial name="_MeasureCard" model="m" />
                }
                @* 0件のときの空表示 *@
                @if (!planned.Any())
                {
                    <div class="text-center text-muted small py-4">
                        <i class="bi bi-inbox d-block fs-4 mb-1 opacity-50"></i>計画中の対策はありません
                    </div>
                }
            </div>
        </div>
    </div>

    @* 進行中レーン *@
    <div class="col-xl-4">
        <div class="kanban-lane shadow-sm">
            <div class="kanban-lane-header lane-progress">
                <i class="bi bi-arrow-repeat text-primary"></i>
                <span>進行中</span>
                <span class="badge bg-primary ms-1">@inProgress.Count</span>
            </div>
            <div class="kanban-lane-body">
                @foreach (var m in inProgress)
                {
                    <partial name="_MeasureCard" model="m" />
                }
                @if (!inProgress.Any())
                {
                    <div class="text-center text-muted small py-4">
                        <i class="bi bi-inbox d-block fs-4 mb-1 opacity-50"></i>進行中の対策はありません
                    </div>
                }
            </div>
        </div>
    </div>

    @* 完了レーン（直近10件のみ表示し残りは件数で丸める） *@
    <div class="col-xl-4">
        <div class="kanban-lane shadow-sm">
            <div class="kanban-lane-header lane-completed">
                <i class="bi bi-check-circle text-success"></i>
                <span>完了</span>
                <span class="badge bg-success ms-1">@completed.Count</span>
            </div>
            <div class="kanban-lane-body">
                @* 先頭10件だけ詳細カードを表示（大量表示による重さを回避） *@
                @foreach (var m in completed.Take(10))
                {
                    <partial name="_MeasureCard" model="m" />
                }
                @if (!completed.Any())
                {
                    <div class="text-center text-muted small py-4">
                        <i class="bi bi-inbox d-block fs-4 mb-1 opacity-50"></i>完了済みの対策はありません
                    </div>
                }
                @* 残件の件数だけ末尾に表示 *@
                @if (completed.Count > 10)
                {
                    <div class="text-center small text-muted py-2">…他 @(completed.Count - 10) 件</div>
                }
            </div>
        </div>
    </div>
</div>
}
