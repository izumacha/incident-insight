@model DashboardViewModel
@{
    ViewData["Title"] = "ダッシュボード";
}

<h2>インシデント分析</h2>
<div class="grid">
    <article>
        <h3>@Model.TotalIncidents</h3>
        <p>総インシデント件数</p>
    </article>
    <article>
        <h3>@Model.OpenCountermeasures</h3>
        <p>未完了の再発防止策</p>
    </article>
</div>

<div class="grid">
    <article>
        <h4>原因分類の傾向</h4>
        <canvas id="categoryChart"></canvas>
    </article>
    <article>
        <h4>月次件数の推移</h4>
        <canvas id="monthlyChart"></canvas>
    </article>
</div>

@section Scripts {
<script>
const categoryLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryStats.Select(x => x.Category)));
const categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryStats.Select(x => x.Count)));
const monthlyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyStats.Select(x => x.Month)));
const monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyStats.Select(x => x.Count)));

new Chart(document.getElementById('categoryChart'), {
  type: 'pie',
  data: {
    labels: categoryLabels,
    datasets: [{ data: categoryData }]
  }
});

new Chart(document.getElementById('monthlyChart'), {
  type: 'line',
  data: {
    labels: monthlyLabels,
    datasets: [{ label: '件数', data: monthlyData, fill: false, tension: 0.25 }]
  }
});
</script>
}
