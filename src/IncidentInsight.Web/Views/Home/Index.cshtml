@* ダッシュボード画面で使う ViewModel の型を宣言 *@
@model IncidentInsight.Web.Models.ViewModels.DashboardViewModel
@* IClock を DI で受け取り、今日の日付を DateTime.Today 直呼びなしで取得する *@
@inject IncidentInsight.Web.Services.IClock Clock
@{
    @* ブラウザタブのタイトル *@
    ViewData["Title"] = "ダッシュボード";
    @* 今日の日付を一度だけ取得してビュー内で使い回す *@
    var today = Clock.Today;
}

@* 画面上部: Hero バナー(プライマリブランド色のグラデーション帯で当期サマリーを掲げる) *@
<section class="hero-banner mb-4">
    @* バナーの中身: 左にタイトル+サマリー、右に期間切替+新規登録 *@
    <div class="hero-content">
        @* バナー左側: タイトルと当期サマリー本文 *@
        <div class="hero-text">
            @* ヒーロー大見出し(白文字) *@
            <h1 class="hero-title"><i class="bi bi-speedometer2 me-2"></i>ダッシュボード</h1>
            @* 当期のサマリー本文(状況に応じて文言を切替: 期限超過あり / 今月発生ゼロ / 通常) *@
            <p class="hero-subtitle">
                @if (Model.OverdueMeasures > 0)
                {
                    @* 期限超過がある場合: 注意喚起を主役に *@
                    <text>期限超過の対策が <strong>@Model.OverdueMeasures 件</strong> あります。早急な対応をお願いします。</text>
                }
                else if (Model.ThisMonthIncidents == 0)
                {
                    @* 今月の発生ゼロ: 安全な状態を称賛 *@
                    <text>今月のインシデント報告はまだありません。引き続き安全な医療の提供をお願いします。</text>
                }
                else
                {
                    @* 通常: 今月の発生件数と完了率を提示 *@
                    <text>今月の発生件数は <strong>@Model.ThisMonthIncidents 件</strong>、再発防止策の完了率は <strong>@Model.CompletionRate%</strong> です。</text>
                }
            </p>
        </div>
        @* バナー右側: 集計期間(週/月/四半期/年)切替 + 新規登録ボタン *@
        <div class="hero-actions">
            @* 集計期間(週/月/四半期/年)の切り替えボタン群 *@
            <div class="btn-group btn-group-sm" role="group" aria-label="期間選択">
                @* 各期間ボタン: アクティブなら btn-primary(白塗り)、非アクティブなら btn-outline-secondary(半透明白枠) *@
                <a class="btn @(Model.Period == "week" ? "btn-primary" : "btn-outline-secondary")" href="?period=week">週</a>
                <a class="btn @(Model.Period == "month" ? "btn-primary" : "btn-outline-secondary")" href="?period=month">月</a>
                <a class="btn @(Model.Period == "quarter" ? "btn-primary" : "btn-outline-secondary")" href="?period=quarter">四半期</a>
                <a class="btn @(Model.Period == "year" ? "btn-primary" : "btn-outline-secondary")" href="?period=year">1年</a>
            </div>
            @* 新規登録ボタン(主要 CTA): 白塗りでプライマリ文字 *@
            <a asp-controller="Incidents" asp-action="Create" class="btn btn-light btn-sm">
                <i class="bi bi-plus-circle me-1"></i>新規登録
            </a>
        </div>
    </div>
</section>

<!-- KPI Cards -->
@* KPI カード4枚(総件数/今月件数/未完了対策/期限超過対策) — 新デザインの kpi-card クラスを利用 *@
<div class="row g-3 mb-4">
    @* 期間内のインシデント総数カード(主役 KPI: kpi-hero 修飾子で他より大きく表示) *@
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card kpi-hero shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                @* アイコン枠(プライマリ色で大きめに) *@
                <div class="kpi-icon bg-primary bg-opacity-10 me-3">
                    <i class="bi bi-clipboard2-pulse fs-2 text-primary"></i>
                </div>
                <div>
                    @* 期間ラベル(週/月/四半期/年) *@
                    <div class="kpi-label">@(Model.Period == "week" ? "週間" : Model.Period == "month" ? "月間" : Model.Period == "quarter" ? "四半期" : "年間")インシデント数</div>
                    @* 件数の大きな数値表示(.kpi-hero の修飾で 3.5rem 相当) *@
                    <div class="kpi-value">@Model.TotalIncidents<span class="unit">件</span></div>
                </div>
            </div>
        </div>
    </div>
    @* 今月のインシデント件数カード(プライマリ系) *@
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="kpi-icon bg-primary bg-opacity-10 me-3">
                    <i class="bi bi-calendar3 fs-3 text-primary"></i>
                </div>
                <div>
                    <div class="kpi-label">今月の発生件数</div>
                    <div class="kpi-value">@Model.ThisMonthIncidents<span class="unit">件</span></div>
                </div>
            </div>
        </div>
    </div>
    @* 未完了対策カード(警告系) *@
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card kpi-warning shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="kpi-icon bg-warning bg-opacity-10 me-3">
                    <i class="bi bi-hourglass-split fs-3 text-warning"></i>
                </div>
                <div>
                    <div class="kpi-label">未完了対策</div>
                    <div class="kpi-value">@Model.OpenMeasures<span class="unit">件</span></div>
                </div>
            </div>
        </div>
    </div>
    @* 期限超過対策カード(危険系。0件のときはアクセントを抑える) *@
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card kpi-danger shadow-sm h-100 @(Model.OverdueMeasures > 0 ? "border border-danger" : "")">
            <div class="card-body d-flex align-items-center">
                <div class="kpi-icon bg-danger bg-opacity-10 me-3">
                    <i class="bi bi-alarm fs-3 text-danger"></i>
                </div>
                <div>
                    <div class="kpi-label">期限超過対策</div>
                    <div class="kpi-value @(Model.OverdueMeasures > 0 ? "text-danger" : "")">
                        @Model.OverdueMeasures<span class="unit">件</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Alert: Overdue Measures -->
@* 期限超過対策がある場合のみ目立つアラートを表示 *@
@if (Model.OverdueMeasures > 0)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <h6 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i>期限超過の対策が @Model.OverdueMeasures 件あります</h6>
        <ul class="mb-0 mt-2">
            @* OverdueMeasureList はコントローラ側で既に代表件数まで絞り込み済み(HomeController.OverdueAlertLimit) *@
            @foreach (var m in Model.OverdueMeasureList)
            {
                @* Date 同士の差分を Days で取ることで時刻部分の切り捨て誤差を防ぐ *@
                var daysOverdue = (today.Date - m.DueDate.Date).Days;
                <li>
                    <strong>@m.Incident?.Department</strong> —
                    @* 長すぎる説明は 40 文字で切って末尾に … を付ける *@
                    @(m.Description.Length > 40 ? m.Description[..40] + "…" : m.Description)
                    <span class="badge bg-danger ms-1">@daysOverdue 日超過</span>
                    担当: @m.ResponsiblePerson
                    @* 1 クリックで完了登録できるフォーム *@
                    <form asp-controller="PreventiveMeasures" asp-action="Complete" asp-route-id="@m.Id"
                          method="post" class="d-inline ms-2">
                        @* CSRF トークン + 楽観ロックトークンを共通部品で必ずセット送信する(送らないと Complete 側で Guid.Empty がピンされ常に衝突扱いになる) *@
                        <partial name="_ConcurrencyTokenFields" model="m.ConcurrencyToken" />
                        <button type="submit" class="btn btn-sm btn-outline-success py-0">完了報告</button>
                    </form>
                </li>
            }
        </ul>
        @* 全件確認リンク(カンバンの「計画中」タブへ) *@
        <a asp-controller="PreventiveMeasures" asp-action="Index" asp-route-status="Planned" class="alert-link mt-2 d-block">
            全件確認 <i class="bi bi-arrow-right"></i>
        </a>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Alert: Recurrence Warnings -->
@* 再発パターン検出アラート(90 日以内に類似インシデントがある場合) *@
@if (Model.RecurrenceAlerts.Any())
{
    <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
        <h6 class="alert-heading"><i class="bi bi-arrow-repeat me-2"></i>再発パターンが検出されました</h6>
        <p class="small mb-2">過去90日間に同じ部署・種別・原因で複数のインシデントが発生しています。根本原因対策の見直しが必要です。</p>
        <ul class="mb-0">
            @* 検出された再発パターンを全件列挙 *@
            @foreach (var alert in Model.RecurrenceAlerts)
            {
                <li>
                    <strong>@alert.PatternDescription</strong> —
                    @alert.SimilarIncidents.Count 件の類似インシデント
                    <a asp-controller="Incidents" asp-action="Details" asp-route-id="@alert.CurrentIncident.Id"
                       class="ms-2 small">詳細 <i class="bi bi-arrow-right"></i></a>
                </li>
            }
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* 有効性評価で再発が確認された対策がある場合のアラート *@
@if (Model.FailedMeasures > 0)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-x-circle-fill me-2"></i>
        有効性評価で<strong>再発が確認された対策が @Model.FailedMeasures 件</strong>あります。
        追加の根本原因分析と対策強化が必要です。
        <a asp-controller="Analytics" asp-action="Index" class="alert-link ms-2">分析ページで確認</a>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Charts + Recent Incidents -->
@* 折れ線グラフ + 最近のインシデントリスト *@
<div class="row g-3 mb-4">
    @* 月別トレンドチャート(Chart.js) *@
    <div class="col-xl-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pb-0">
                <h6 class="mb-0"><i class="bi bi-graph-up me-2 text-primary"></i>月別インシデント発生推移（過去12ヶ月）</h6>
            </div>
            <div class="card-body">
                @* Chart.js が描画対象とする canvas *@
                <canvas id="trendChart" height="100"></canvas>
            </div>
        </div>
    </div>
    @* 最近のインシデント(5 件)カード *@
    <div class="col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pb-0">
                <h6 class="mb-0"><i class="bi bi-clock-history me-2 text-secondary"></i>最近のインシデント</h6>
            </div>
            <div class="card-body p-0">
                @* データ無しの場合は登録を促すメッセージ *@
                @if (!Model.RecentIncidents.Any())
                {
                    <div class="text-center py-4 px-3">
                        <i class="bi bi-clipboard2-plus display-5 text-primary d-block mb-2"></i>
                        <p class="text-muted small mb-2">インシデントがまだ登録されていません</p>
                        <a asp-controller="Incidents" asp-action="Create" class="btn btn-primary btn-sm">
                            <i class="bi bi-plus-circle me-1"></i>最初のインシデントを登録
                        </a>
                    </div>
                }
                else
                {
                @* インシデントを 1 件ずつリスト表示 *@
                <ul class="list-group list-group-flush">
                    @foreach (var incident in Model.RecentIncidents)
                    {
                        @* 期限超過の対策を持つ場合は赤背景で強調(IClock 経由の today を渡す) *@
                        <li class="list-group-item px-3 py-2 @(incident.PreventiveMeasures.Any(m => m.IsOverdueOn(today)) ? "list-group-item-danger" : "")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <span class="badge bg-@incident.SeverityColor me-1">@incident.SeverityLabel</span>
                                    <a asp-controller="Incidents" asp-action="Index"
                                       asp-route-department="@incident.Department"
                                       class="small fw-medium text-decoration-none">@incident.Department</a>
                                    <div class="text-muted small">@incident.IncidentTypeLabel · @incident.OccurredAt.ToString("M/d")</div>
                                </div>
                                <a asp-controller="Incidents" asp-action="Details" asp-route-id="@incident.Id"
                                   class="btn btn-sm btn-outline-secondary py-0">詳細</a>
                            </div>
                        </li>
                    }
                </ul>
                }
                <div class="p-3">
                    @* インシデント一覧ページへのリンク *@
                    <a asp-controller="Incidents" asp-action="Index" class="btn btn-outline-primary btn-sm w-100">
                        全件表示 <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Completion Rate -->
@* 対策の完了率カード + 期限超過一覧カード *@
<div class="row g-3">
    @* 完了率プログレスバー *@
    <div class="col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pb-0">
                <h6 class="mb-0"><i class="bi bi-check2-all me-2 text-success"></i>再発防止策 完了率</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-1">
                    <span>完了率</span>
                    <strong>@Model.CompletionRate%</strong>
                </div>
                @* プログレスバーで完了率を視覚化 *@
                <div class="progress mb-3" style="height: 20px;">
                    <div class="progress-bar bg-success" role="progressbar"
                         style="width: @Model.CompletionRate%"
                         aria-valuenow="@Model.CompletionRate" aria-valuemin="0" aria-valuemax="100">
                        @Model.CompletionRate%
                    </div>
                </div>
                @* 完了/未完了/期限超過の内訳 *@
                <div class="row text-center">
                    <div class="col-4">
                        <div class="text-success fw-bold fs-5">@Model.CompletedMeasures</div>
                        <div class="text-muted small">完了</div>
                    </div>
                    <div class="col-4">
                        <div class="text-warning fw-bold fs-5">@Model.OpenMeasures</div>
                        <div class="text-muted small">未完了</div>
                    </div>
                    <div class="col-4">
                        <div class="text-danger fw-bold fs-5">@Model.OverdueMeasures</div>
                        <div class="text-muted small">期限超過</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @* 期限超過対策の一覧(最大 @(IncidentInsight.Web.Controllers.HomeController.OverdueAlertLimit) 件) *@
    <div class="col-xl-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pb-0">
                <h6 class="mb-0"><i class="bi bi-alarm me-2 text-danger"></i>期限超過の対策一覧</h6>
            </div>
            <div class="card-body p-0">
                @* 超過なしの場合は「無し」メッセージ *@
                @if (!Model.OverdueMeasureList.Any())
                {
                    <div class="p-3 text-muted text-center">
                        <i class="bi bi-check-circle text-success fs-4 d-block mb-1"></i>
                        期限超過の対策はありません
                    </div>
                }
                else
                {
                    @* OverdueMeasureList はコントローラ側で既に代表件数まで絞り込み済み(HomeController.OverdueAlertLimit) *@
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <tbody>
                                @foreach (var m in Model.OverdueMeasureList)
                                {
                                    @* Date 同士の差分を Days で取ることで時刻部分の切り捨て誤差を防ぐ *@
                                    var days = (today.Date - m.DueDate.Date).Days;
                                    <tr>
                                        <td class="ps-3">
                                            <div class="small fw-medium">@(m.Description.Length > 35 ? m.Description[..35] + "…" : m.Description)</div>
                                            <div class="text-muted x-small">@m.ResponsiblePerson · @m.ResponsibleDepartment</div>
                                        </td>
                                        <td class="text-end pe-3 align-middle">
                                            <span class="badge bg-danger">@days 日超過</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="p-2 text-end">
                        @* カンバン全件表示へのリンク *@
                        <a asp-controller="PreventiveMeasures" asp-action="Index" class="btn btn-sm btn-outline-danger">
                            全件管理 <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ページ固有の JavaScript(Chart.js 初期化) *@
@* Razor から TypeScript (Scripts/dashboard.ts) へデータを渡す仕組み: *@
@*   1) <script type="application/json"> でデータを埋め込む(HTML エスケープ済み) *@
@*   2) dashboard.js が IIFE で起動し、その JSON を読み取って Chart.js を初期化する *@
@* これにより従来の inline script が TypeScript の型チェック対象になる *@
@section Scripts {
    @* ダッシュボード用データ(月別件数配列と折れ線の配色) *@
    <script id="dashboard-data" type="application/json">
        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
            monthlyData = Model.MonthlyCounts.Select(m => new { m.Label, m.Count }),
            primaryColor = "#1a6dbf",
            primaryColorRgba = "rgba(26,109,191,0.10)"
        }))
    </script>
    @* TypeScript からコンパイルされた dashboard.js を読み込む *@
    @* CDN の Chart.js (グローバル Chart) はレイアウトで先に読み込まれているため、この時点で利用可能 *@
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
}
