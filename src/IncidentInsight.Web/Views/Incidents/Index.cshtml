@model IncidentInsight.Web.Models.ViewModels.IncidentListViewModel
@{
    ViewData["Title"] = "インシデント一覧";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-clipboard2-pulse me-2 text-primary"></i>インシデント一覧</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>新規登録
    </a>
</div>

<!-- Filter Panel -->
@{
    var anyFilter = !string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Department)
                 || Model.IncidentType.HasValue || Model.Severity.HasValue
                 || Model.DateFrom.HasValue || Model.DateTo.HasValue || Model.CauseCategoryId.HasValue;
}
<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white" role="button" data-bs-toggle="collapse" data-bs-target="#filterPanel">
        <i class="bi bi-funnel me-2"></i>絞り込み
        @if (anyFilter)
        {
            <span class="badge bg-primary ms-2">フィルター適用中</span>
        }
    </div>
    <div class="collapse @(anyFilter ? "show" : "")" id="filterPanel">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-2">
                    <div class="col-md-3">
                        <input type="text" name="search" class="form-control form-control-sm"
                               placeholder="キーワード検索（内容・報告者）" value="@Model.Search" />
                    </div>
                    <div class="col-md-2">
                        <select name="department" class="form-select form-select-sm">
                            <option value="">部署（全て）</option>
                            @foreach (var d in IncidentInsight.Web.Models.Incident.Departments)
                            {
                                <option value="@d" selected="@(Model.Department == d)">@d</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="incidentType" class="form-select form-select-sm">
                            <option value="">種別（全て）</option>
                            @foreach (var t in IncidentInsight.Web.Models.Enums.IncidentTypeMapping.AllInDisplayOrder)
                            {
                                <option value="@t" selected="@(Model.IncidentType == t)">@IncidentInsight.Web.Models.Enums.IncidentTypeMapping.JapaneseLabel(t)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="severity" class="form-select form-select-sm">
                            <option value="">重症度（全て）</option>
                            @foreach (var s in IncidentInsight.Web.Models.Enums.EnumLabels.AllSeverities)
                            {
                                <option value="@s" selected="@(Model.Severity == s)">@IncidentInsight.Web.Models.Enums.EnumLabels.Japanese(s)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <select name="causeCategoryId" class="form-select form-select-sm">
                            <option value="">原因分類（全て）</option>
                            @foreach (var opt in Model.CauseCategoryOptions)
                            {
                                <option value="@opt.Value" selected="@(Model.CauseCategoryId?.ToString() == opt.Value)">@opt.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-primary btn-sm w-100">検索</button>
                    </div>
                </div>
                <div class="row g-2 mt-1 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label small mb-0">発生日（開始）</label>
                        <input type="date" name="dateFrom" class="form-control form-control-sm"
                               value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-0">発生日（終了）</label>
                        <input type="date" name="dateTo" class="form-control form-control-sm"
                               value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-0">並び順</label>
                        <select name="sortBy" class="form-select form-select-sm">
                            <option value="latest" selected="@(Model.SortBy != "severity" && Model.SortBy != "overdue")">最新順</option>
                            <option value="severity" selected="@(Model.SortBy == "severity")">重症度高順</option>
                            <option value="overdue" selected="@(Model.SortBy == "overdue")">未完了対策あり優先</option>
                        </select>
                    </div>
                    <div class="col-md-auto">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">クリア</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Results -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between">
        <span class="text-muted small">@Model.TotalCount 件中 @((Model.Page - 1) * Model.PageSize + (Model.TotalCount > 0 ? 1 : 0))〜@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) 件表示</span>
    </div>
    @if (!Model.Incidents.Any())
    {
        var hasFilter = !string.IsNullOrEmpty(Model.Search) || !string.IsNullOrEmpty(Model.Department)
                     || Model.IncidentType.HasValue || Model.Severity.HasValue
                     || Model.DateFrom.HasValue || Model.DateTo.HasValue;
        if (hasFilter)
        {
            <div class="card-body text-center py-5">
                <i class="bi bi-search display-4 text-muted d-block mb-3"></i>
                <h5 class="text-muted">絞り込み条件に一致するインシデントはありません</h5>
                <p class="text-muted small mb-3">検索条件を変更するか、フィルターをクリアしてください</p>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i>フィルターをクリア
                </a>
            </div>
        }
        else
        {
            <div class="card-body text-center py-5">
                <i class="bi bi-clipboard2-plus display-4 text-primary d-block mb-3"></i>
                <h5>インシデントがまだ登録されていません</h5>
                <p class="text-muted mb-3">インシデントを登録して、再発防止の取り組みを始めましょう。</p>
                <a asp-action="Create" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>最初のインシデントを登録する
                </a>
            </div>
        }
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">発生日時</th>
                        <th>部署</th>
                        <th>種別</th>
                        <th>重症度</th>
                        <th>報告者</th>
                        <th>対策状況</th>
                        <th class="text-end pe-3">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var incident in Model.Incidents)
                    {
                        <tr class="@(incident.PreventiveMeasures.Any(m => m.IsOverdue) ? "table-danger" : "")">
                            <td class="ps-3">
                                <div>@incident.OccurredAt.ToString("yyyy/MM/dd")</div>
                                <div class="text-muted small">@incident.OccurredAt.ToString("HH:mm")</div>
                            </td>
                            <td>@incident.Department</td>
                            <td>
                                <span class="badge bg-secondary">@incident.IncidentTypeLabel</span>
                            </td>
                            <td>
                                <span class="badge bg-@incident.SeverityColor">@incident.SeverityLabel</span>
                            </td>
                            <td>@incident.ReporterName</td>
                            <td>
                                <span class="badge bg-@incident.MeasureStatusColor">@incident.MeasureStatusSummary</span>
                            </td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-route-id="@incident.Id" class="btn btn-sm btn-outline-primary">詳細</a>
                                <a asp-action="Edit" asp-route-id="@incident.Id" class="btn btn-sm btn-outline-secondary">編集</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-page="@i"
                       asp-route-search="@Model.Search"
                       asp-route-department="@Model.Department"
                       asp-route-incidentType="@Model.IncidentType"
                       asp-route-severity="@Model.Severity"
                       asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                       asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
                       asp-route-causeCategoryId="@Model.CauseCategoryId"
                       asp-route-sortBy="@Model.SortBy">@i</a>
                </li>
            }
        </ul>
    </nav>
}
