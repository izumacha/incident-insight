@* 使用する ViewModel の型を宣言（基本情報+原因分析+対策一覧をまとめた登録フォーム用の入れ物） *@
@model IncidentInsight.Web.Models.ViewModels.IncidentCreateEditViewModel
@* IClock を DI で受け取り、今日の日付を DateTime.Today 直呼びなしで取得する *@
@inject IncidentInsight.Web.Services.IClock Clock
@{
    @* ブラウザタブに表示するタイトル *@
    ViewData["Title"] = "インシデント新規登録";
    @* 今日の日付を IClock 経由で取得して DueDate の初期値などに使う *@
    var today = Clock.Today;
    @* 画面に描画する対策行のリスト。バリデーション失敗後の再描画では入力済みの Model.Measures を
       そのまま使い、初回表示などで1件も無ければ空行を1件補って「最低1件必須」の入力欄を保証する *@
    var measureRows = (Model.Measures != null && Model.Measures.Count > 0)
        ? Model.Measures
        : new List<IncidentInsight.Web.Models.ViewModels.MeasureFormViewModel> { new() };
    @* 対策の実施期限の既定値。日数はコントローラの定数（唯一の源）を参照し、二重定義を避ける *@
    var defaultDueDate = today.AddDays(IncidentInsight.Web.Controllers.IncidentsController.DefaultMeasureDueDays);
    @* JS が行テンプレートを複製するときに実際の添字へ置き換える仮の添字文字列（Razor と JS で共有） *@
    const string MeasureIndexSentinel = "__INDEX__";

    @* 対策行1件分のマークアップを描画するローカル関数。
       サーバー描画の @for ループと、JS「対策を追加」用の <template> の両方がこの関数を使うことで、
       行マークアップの二重管理（コピーのズレ）を防ぐ唯一の源になっている。
       index: name 属性の添字（数値文字列、テンプレートでは仮の MeasureIndexSentinel）
       displayNumber: 見出し「対策 N」の人間向け連番（追加・削除後は JS の reindexMeasures が振り直す）
       m: 復元する入力値を持つ ViewModel（テンプレートでは既定値だけの新規インスタンス）
       deletable: 削除ボタンを表示するか（1行目は最低1件必須のため削除不可）
       ※ <option> がタグヘルパー扱いになるため async Task 必須（MVC1006） *@
    async Task RenderMeasureRowAsync(string index, int displayNumber, IncidentInsight.Web.Models.ViewModels.MeasureFormViewModel m, bool deletable)
    {
        @* 実施期限に「ユーザーが実際に送信した文字列」(ModelState の AttemptedValue)が残っていれば最優先で使う。
           解析不能な日付を既定値で上書き表示すると、隣に出るエラーの原因が見えなくなるため *@
        var attemptedDueDate = ViewContext.ViewData.ModelState[$"Measures[{index}].DueDate"]?.AttemptedValue;
        @* 表示する実施期限: 送信文字列 → バインド済みの値 → 既定値（今日+既定日数）の順で決める
           （DueDate は Required を機能させるため nullable。未入力は null になるので ?? で既定値に落とす） *@
        var dueDateValue = attemptedDueDate
            ?? (m.DueDate ?? defaultDueDate).ToString("yyyy-MM-dd");
        @* 対策行の外枠（name の添字 Measures[index] がモデルバインドの行番号になる） *@
        <div class="measure-row border rounded-3 p-3 mb-3 bg-light">
            <div class="d-flex justify-content-between align-items-center mb-2">
                @* 行タイトル（人間向けの連番） *@
                <h6 class="mb-0">対策 @displayNumber</h6>
                @* 2行目以降にだけ削除ボタンを付ける（1行目は最低1件必須のため削除不可） *@
                @if (deletable)
                {
                    <button type="button" class="btn btn-outline-danger btn-sm py-0" onclick="removeMeasureRow(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                }
            </div>
            <div class="row g-2">
                <div class="col-12">
                    @* 対策内容（必須）。textarea の中身に投稿済みの値を復元する *@
                    <label class="form-label small fw-medium">対策内容 <span class="text-danger">*</span></label>
                    <textarea name="Measures[@(index)].Description" class="form-control form-control-sm" rows="2"
                              placeholder="具体的な再発防止策（5W1Hで記載）">@m.Description</textarea>
                </div>
                <div class="col-md-3">
                    @* 対策種別（短期 or 長期）。投稿済みの選択値に selected を付けて復元する *@
                    <label class="form-label small">対策種別</label>
                    <select name="Measures[@(index)].MeasureType" class="form-select form-select-sm">
                        @* MeasureType は Required を機能させるため nullable。未設定(null)の行は
                           既定の「短期対策」を選択表示する(LongTerm 以外はすべて短期扱い) *@
                        <option value="ShortTerm" selected="@(m.MeasureType != IncidentInsight.Web.Models.Enums.MeasureTypeKind.LongTerm)">短期対策（即時〜1ヶ月）</option>
                        <option value="LongTerm" selected="@(m.MeasureType == IncidentInsight.Web.Models.Enums.MeasureTypeKind.LongTerm)">長期対策（仕組み改善）</option>
                    </select>
                </div>
                <div class="col-md-3">
                    @* 担当者（必須）。投稿済みの値を value で復元する *@
                    <label class="form-label small">担当者 <span class="text-danger">*</span></label>
                    <input name="Measures[@(index)].ResponsiblePerson" class="form-control form-control-sm"
                           value="@m.ResponsiblePerson" />
                </div>
                <div class="col-md-3">
                    @* 担当部署（必須）。投稿済みの値を value で復元する *@
                    <label class="form-label small">担当部署 <span class="text-danger">*</span></label>
                    <input name="Measures[@(index)].ResponsibleDepartment" class="form-control form-control-sm"
                           value="@m.ResponsibleDepartment" />
                </div>
                <div class="col-md-2">
                    @* 実施期限（初期値は既定日数後。解析不能な送信値は空欄のまま再表示される） *@
                    <label class="form-label small">実施期限 <span class="text-danger">*</span></label>
                    <input type="date" name="Measures[@(index)].DueDate" class="form-control form-control-sm"
                           value="@dueDateValue" />
                </div>
                <div class="col-md-1">
                    @* 優先度（高=1／中=2／低=3）。投稿済みの選択値に selected を付けて復元する *@
                    <label class="form-label small">優先度</label>
                    <select name="Measures[@(index)].Priority" class="form-select form-select-sm">
                        <option value="1" selected="@(m.Priority == 1)">高</option>
                        <option value="2" selected="@(m.Priority == 2)">中</option>
                        <option value="3" selected="@(m.Priority == 3)">低</option>
                    </select>
                </div>
                <div class="col-12">
                    @* 立案根拠メモ（任意）。textarea の中身に投稿済みの値を復元する *@
                    <label class="form-label small">立案根拠・背景メモ <span class="text-muted">(任意)</span></label>
                    <textarea name="Measures[@(index)].AnalysisNote" class="form-control form-control-sm" rows="1"
                              placeholder="なぜこの対策を選んだか、根本原因との対応を記入">@m.AnalysisNote</textarea>
                </div>
            </div>
        </div>
    }
}

@* ページヘッダ：見出しと一覧画面に戻るボタンを横並びに配置 *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-plus-circle me-2 text-primary"></i>インシデント新規登録</h2>
    @* 一覧へ戻るリンク（入力内容は破棄される） *@
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>一覧へ
    </a>
</div>

@* フォーム全体を囲むカード *@
<div class="card border-0 shadow-sm">
    <div class="card-body p-4">
        @* 送信先は Create アクション。送信直前に JS で対策行の添字を詰め直す *@
        <form asp-action="Create" method="post" id="createForm" onsubmit="reindexMeasures()">
            @* CSRF 対策のトークン *@
            @Html.AntiForgeryToken()

            @* サーバー側バリデーションエラーがあれば一覧表示 *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger mb-4" id="errorSummary">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>入力内容を確認してください</strong>
                    @* ModelState のエラー全件を小さめ文字で表示 *@
                    <div asp-validation-summary="All" class="mt-1 mb-0 small"></div>
                </div>
            }

            @* ウィザード風に3ステップに分けるタブ *@
            <ul class="nav nav-tabs mb-4" id="wizardTabs" role="tablist">
                <li class="nav-item">
                    @* ステップ1：基本情報（初期表示） *@
                    <button class="nav-link active" id="tab1-tab" data-bs-toggle="tab" data-bs-target="#tab1" type="button">
                        <span class="badge bg-primary me-1">1</span> 基本情報
                    </button>
                </li>
                <li class="nav-item">
                    @* ステップ2：なぜなぜ分析 *@
                    <button class="nav-link" id="tab2-tab" data-bs-toggle="tab" data-bs-target="#tab2" type="button">
                        <span class="badge bg-secondary me-1">2</span> 原因分析
                    </button>
                </li>
                <li class="nav-item">
                    @* ステップ3：再発防止策 *@
                    <button class="nav-link" id="tab3-tab" data-bs-toggle="tab" data-bs-target="#tab3" type="button">
                        <span class="badge bg-secondary me-1">3</span> 再発防止策
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="wizardContent">
                @* タブ1：基本情報（発生日時・部署・種別など） *@
                <div class="tab-pane fade show active" id="tab1">
                    <div class="row g-3">
                        <div class="col-md-4">
                            @* 発生日時（必須） *@
                            <label asp-for="OccurredAt" class="form-label fw-medium"></label> <span class="text-danger">*</span>
                            <input asp-for="OccurredAt" type="datetime-local" class="form-control" />
                            <span asp-validation-for="OccurredAt" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            @* 発生部署（Incident の静的リストから選択） *@
                            <label asp-for="Department" class="form-label fw-medium"></label> <span class="text-danger">*</span>
                            <select asp-for="Department" class="form-select">
                                <option value="">-- 選択してください --</option>
                                @* Incident.Departments の全部署を順にオプション化 *@
                                @foreach (var d in IncidentInsight.Web.Models.Incident.Departments)
                                {
                                    <option value="@d">@d</option>
                                }
                            </select>
                            <span asp-validation-for="Department" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            @* インシデント種別（enum を表示順で列挙） *@
                            <label asp-for="IncidentType" class="form-label fw-medium"></label> <span class="text-danger">*</span>
                            <select asp-for="IncidentType" class="form-select">
                                <option value="">-- 選択してください --</option>
                                @* 種別 enum を表示順で列挙し日本語ラベルで表示 *@
                                @foreach (var t in IncidentInsight.Web.Models.Enums.IncidentTypeMapping.AllInDisplayOrder)
                                {
                                    <option value="@t">@IncidentInsight.Web.Models.Enums.IncidentTypeMapping.JapaneseLabel(t)</option>
                                }
                            </select>
                            <span asp-validation-for="IncidentType" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            @* 重症度（Level0〜Level5） *@
                            <label asp-for="Severity" class="form-label fw-medium"></label>
                            <select asp-for="Severity" class="form-select">
                                @* 全重症度を日本語ラベル付きで選択肢化 *@
                                @foreach (var s in IncidentInsight.Web.Models.Enums.EnumLabels.AllSeverities)
                                {
                                    <option value="@s">@IncidentInsight.Web.Models.Enums.EnumLabels.Japanese(s)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            @* 報告者氏名（必須） *@
                            <label asp-for="ReporterName" class="form-label fw-medium"></label> <span class="text-danger">*</span>
                            <input asp-for="ReporterName" class="form-control" placeholder="氏名（例：山田 花子）" />
                            <span asp-validation-for="ReporterName" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            @* 発生内容の詳細記述（必須） *@
                            <label asp-for="Description" class="form-label fw-medium"></label> <span class="text-danger">*</span>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="いつ・どこで・誰が・何を・どのようにしたかを具体的に記述（例：夜勤帯にAさんの薬をBさんに投与した）"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            @* 発生直後の応急処置（任意） *@
                            <label asp-for="ImmediateActions" class="form-label fw-medium"></label>
                            <textarea asp-for="ImmediateActions" class="form-control" rows="3"
                                      placeholder="発生直後の応急処置・報告先・患者への対応内容（任意）"></textarea>
                            <div class="form-text">任意項目です。発生直後に取った対応があれば記入してください。</div>
                        </div>
                        <div class="col-12 d-flex justify-content-end">
                            @* タブ2へ進むボタン *@
                            <button type="button" class="btn btn-primary" onclick="goToTab('tab2')">
                                次へ：原因分析 <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </div>
                </div>

                @* タブ2：なぜなぜ分析（5回「なぜ？」を繰り返して根本原因を掘り下げる） *@
                <div class="tab-pane fade" id="tab2">
                    <div class="alert alert-info small mb-3">
                        <i class="bi bi-lightbulb me-2"></i>
                        <strong>なぜなぜ分析のポイント：</strong>
                        「なぜ1」から始めて「なぜ？」を繰り返すことで、表面的な原因ではなく<strong>根本原因</strong>まで掘り下げます。
                        なぜ5まで掘り下げることで、再発防止に本当に効果ある対策が立案できます。
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            @* 原因分類（親カテゴリ配下の末端カテゴリを optgroup で表示） *@
                            <label asp-for="CauseAnalysis.CauseCategoryId" class="form-label fw-medium"></label>
                            <select asp-for="CauseAnalysis.CauseCategoryId"
                                    asp-items="Model.CauseCategoryOptions"
                                    class="form-select">
                                <option value="">-- 原因分類を選択 --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            @* 分析者氏名 *@
                            <label asp-for="CauseAnalysis.AnalystName" class="form-label fw-medium"></label>
                            <input asp-for="CauseAnalysis.AnalystName" class="form-control" placeholder="分析者氏名" />
                        </div>
                        <div class="col-12">
                            @* なぜ1：直接の原因 *@
                            <label asp-for="CauseAnalysis.Why1" class="form-label fw-medium text-primary"></label>
                            <textarea asp-for="CauseAnalysis.Why1" class="form-control" rows="2"
                                      placeholder="何が起きたか・直接の原因は何か"></textarea>
                        </div>
                        <div class="col-12 text-center text-muted">↓ なぜ？</div>
                        <div class="col-12">
                            @* なぜ2：なぜ1が起きた原因 *@
                            <label asp-for="CauseAnalysis.Why2" class="form-label fw-medium"></label>
                            <textarea asp-for="CauseAnalysis.Why2" class="form-control" rows="2" placeholder="なぜ1が起きた原因"></textarea>
                        </div>
                        <div class="col-12 text-center text-muted">↓ なぜ？</div>
                        <div class="col-12">
                            @* なぜ3：なぜ2が起きた原因 *@
                            <label asp-for="CauseAnalysis.Why3" class="form-label fw-medium"></label>
                            <textarea asp-for="CauseAnalysis.Why3" class="form-control" rows="2" placeholder="なぜ2が起きた原因"></textarea>
                        </div>
                        <div class="col-12 text-center text-muted">↓ なぜ？</div>
                        <div class="col-12">
                            @* なぜ4：なぜ3が起きた原因 *@
                            <label asp-for="CauseAnalysis.Why4" class="form-label fw-medium"></label>
                            <textarea asp-for="CauseAnalysis.Why4" class="form-control" rows="2" placeholder="なぜ3が起きた原因"></textarea>
                        </div>
                        <div class="col-12 text-center text-muted">↓ なぜ？</div>
                        <div class="col-12">
                            @* なぜ5：最深層の根本原因（赤枠で強調） *@
                            <label asp-for="CauseAnalysis.Why5" class="form-label fw-medium text-danger"></label>
                            <textarea asp-for="CauseAnalysis.Why5" class="form-control border-danger" rows="2"
                                      placeholder="これ以上掘り下げられない根本的な原因（対策はここに向けて立案する）"></textarea>
                        </div>
                        <div class="col-12">
                            @* 根本原因の一文要約 *@
                            <label asp-for="CauseAnalysis.RootCauseSummary" class="form-label fw-medium"></label>
                            <input asp-for="CauseAnalysis.RootCauseSummary" class="form-control"
                                   placeholder="根本原因を一文で要約してください" />
                        </div>
                        <div class="col-12 d-flex justify-content-between">
                            @* タブ1へ戻るボタン *@
                            <button type="button" class="btn btn-outline-secondary" onclick="goToTab('tab1')">
                                <i class="bi bi-arrow-left me-1"></i>前へ
                            </button>
                            @* タブ3へ進むボタン *@
                            <button type="button" class="btn btn-primary" onclick="goToTab('tab3')">
                                次へ：再発防止策 <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </div>
                </div>

                @* タブ3：再発防止策（1件以上の登録が必須） *@
                <div class="tab-pane fade" id="tab3">
                    <div class="alert alert-success small mb-3">
                        <i class="bi bi-shield-check me-2"></i>
                        <strong>効果的な再発防止策のポイント：</strong>
                        根本原因に対応した対策を立案してください。
                        「誰が」「何を」「いつまでに」を明確にし、短期対策と長期対策の両方を検討しましょう。
                    </div>
                    @* 対策行の入れ物（JS で動的に追加／削除される） *@
                    <div id="measuresContainer">
                        @* 対策行を Model の内容から描画する。バリデーション失敗後の POST-back でも
                           入力済みの全行（値付き）が復元されるよう、固定の空行1件ではなくループで出力する *@
                        @for (var j = 0; j < measureRows.Count; j++)
                        {
                            @* j 行目の対策行を共通のローカル関数で描画（1行目は最低1件必須のため削除不可） *@
                            await RenderMeasureRowAsync(j.ToString(), j + 1, measureRows[j], deletable: j > 0);
                        }
                    </div>

                    @* JS「対策を追加」用の行テンプレート。中身は上のループと同じ RenderMeasureRowAsync が
                       既定値で1回だけ描画する（行マークアップの唯一の源）。name の添字は仮の
                       MeasureIndexSentinel で出力し、JS が複製時に実際の添字へ置換する。
                       <template> の中身は描画も送信もされない不活性な DOM なので仮の添字でも安全。
                       見出し番号は仮に 0 を渡すが、追加直後に reindexMeasures が正しい連番へ振り直す *@
                    <template id="measure-row-template">
                        @{ await RenderMeasureRowAsync(MeasureIndexSentinel, 0, new IncidentInsight.Web.Models.ViewModels.MeasureFormViewModel(), deletable: true); }
                    </template>

                    @* 対策行を追加するボタン（JS の addMeasureRow を呼ぶ） *@
                    <button type="button" class="btn btn-outline-success btn-sm mb-4" onclick="addMeasureRow()">
                        <i class="bi bi-plus-circle me-1"></i>対策を追加
                    </button>

                    <div class="d-flex justify-content-between">
                        @* タブ2へ戻るボタン *@
                        <button type="button" class="btn btn-outline-secondary" onclick="goToTab('tab2')">
                            <i class="bi bi-arrow-left me-1"></i>前へ
                        </button>
                        @* 登録実行ボタン（フォーム全体を送信） *@
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="bi bi-check-circle me-2"></i>インシデントを登録する
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
@* クライアント側のバリデーションスクリプトを読み込み *@
<partial name="_ValidationScriptsPartial" />
<script>
// 指定したタブIDにフォーカスを移すヘルパー
function goToTab(tabId) {
    // Bootstrap タブの切替をクリックで発火
    document.getElementById(tabId + '-tab').click();
    // active クラスを確実に付与（稀に発火しないケースの保険）
    document.getElementById(tabId + '-tab').classList.add('active');
}

// ページ読込時：バリデーションエラーがあれば最初のエラー項目を含むタブへ自動遷移
document.addEventListener('DOMContentLoaded', function() {
    // エラーサマリ要素が無ければ何もしない
    const errorSummary = document.getElementById('errorSummary');
    if (!errorSummary) return;
    // 最初のエラー表示項目を探す
    const firstInvalid = document.querySelector('.field-validation-error, [class*="input-validation-error"]');
    if (!firstInvalid) return;
    // その項目を含むタブ要素を取得
    const tab = firstInvalid.closest('.tab-pane');
    // 見つかればそのタブに切り替え
    if (tab) goToTab(tab.id);
});

// 対策行の name 添字（Measures[i]）と見出し「対策 N」を、画面上の並び順どおりに振り直す。
// 送信直前（form の onsubmit）・行追加後・行削除後の3か所から呼ばれる共通関数
function reindexMeasures() {
    // 対策行を画面上の順に走査
    document.querySelectorAll('#measuresContainer .measure-row').forEach((row, i) => {
        // 各要素の name 属性の添字部分を i に置換（モデルバインドは 0 始まりの連番を要求する）
        row.querySelectorAll('[name]').forEach(el => {
            el.name = el.name.replace(/Measures\[\d+\]/, `Measures[${i}]`);
        });
        // 行の見出し要素を取得
        const header = row.querySelector('h6');
        // 見出しの連番も並び順に合わせて振り直す（削除しても欠番・重複が出ないようにする）
        if (header) header.textContent = `対策 ${i + 1}`;
    });
}

// 削除ボタンから呼ばれる関数：行を取り除き、残った行の添字と見出しを詰め直す
function removeMeasureRow(button) {
    // ボタンを含む対策行を DOM から削除
    button.closest('.measure-row').remove();
    // 添字と見出し「対策 N」を先頭から振り直す
    reindexMeasures();
}

// 「対策を追加」ボタンから呼ばれる関数：サーバー描画の <template>（Razor ループと同一マークアップの
// 唯一の源）を複製して末尾に追加する。JS 側にマークアップの写しを持たないため、二重管理のズレが起きない
function addMeasureRow() {
    // 追加先コンテナ
    const container = document.getElementById('measuresContainer');
    // Razor が既定値で描画した行テンプレート
    const template = document.getElementById('measure-row-template');
    // テンプレートの中身（対策行1件分の div）を複製する
    const row = template.content.firstElementChild.cloneNode(true);
    // 新しい行の添字 = 現在の行数（reindexMeasures が常に 0..n-1 に詰めるので行数がそのまま次の添字になる）
    const index = container.querySelectorAll('.measure-row').length;
    // name 属性の仮の添字プレースホルダを実際の添字に置換する
    row.querySelectorAll('[name]').forEach(el => {
        el.name = el.name.replace('@MeasureIndexSentinel', index);
    });
    // 複製した行をコンテナ末尾に追加
    container.appendChild(row);
    // 見出し「対策 N」をテンプレートの仮番号から正しい連番へ振り直す
    reindexMeasures();
}
</script>
}
