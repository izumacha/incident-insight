{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "removeComments": false,
    "outDir": "src/IncidentInsight.Web/wwwroot/js",
    "rootDir": "src/IncidentInsight.Web/Scripts"
  },
  "include": ["src/IncidentInsight.Web/Scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
